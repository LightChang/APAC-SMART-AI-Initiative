---
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-2xl bg-gradient-to-br from-navy to-navy-light p-8 sm:p-12 text-center">
      <Icon name="lucide:quote" class="mx-auto h-8 w-8 text-cyan/40 mb-6" />
      <blockquote class="text-lg sm:text-xl font-medium text-white/90 leading-relaxed italic">
        {t(locale, 'founderQuote.quote')}
      </blockquote>
      <div class="mt-6 flex items-center justify-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10">
          <Icon name="lucide:user" class="h-5 w-5 text-cyan" />
        </div>
        <div class="text-left">
          <p class="text-sm font-bold text-white">{t(locale, 'founderQuote.name')}</p>
          <p class="text-xs text-white/60">{t(locale, 'founderQuote.title')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
