---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { t } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';
import partners from '@/assets/data/partners.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-16 sm:py-24 bg-slate-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title={t(locale, 'partners.title')}
      subtitle={t(locale, 'partners.subtitle')}
    />

    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {partners.map((partner) => (
        <div class="flex items-center justify-center rounded-xl border border-border bg-white px-4 py-6 text-center transition-shadow hover:shadow-md">
          <span class="text-sm font-medium text-navy-light">{partner.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
