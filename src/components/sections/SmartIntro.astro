---
import { Icon } from 'astro-icon/components';
import { t, getLocalizedPath } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="py-16 sm:py-24 bg-slate-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Text -->
      <div>
        <h2 class="font-heading text-3xl font-bold text-navy sm:text-4xl">
          {t(locale, 'smartIntro.title')}
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          {t(locale, 'smartIntro.description')}
        </p>
        <a
          href={getLocalizedPath(locale, 'smart-on-fhir')}
          class="mt-6 inline-flex items-center gap-1 text-cyan font-medium hover:text-cyan-dark transition-colors"
        >
          {t(locale, 'smartIntro.link')}
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <!-- Concept diagram -->
      <div class="flex justify-center">
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:gap-6">
          <!-- EHR -->
          <div class="flex flex-col items-center rounded-2xl border-2 border-navy/20 bg-white p-6 text-center w-40">
            <Icon name="lucide:database" class="h-10 w-10 text-navy mb-2" />
            <span class="text-sm font-bold text-navy">EHR</span>
            <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.ehrDesc')}</span>
          </div>

          <Icon name="lucide:arrow-right" class="h-6 w-6 text-cyan rotate-90 sm:rotate-0" />

          <!-- SMART Layer -->
          <div class="flex flex-col items-center rounded-2xl border-2 border-cyan bg-cyan/5 p-6 text-center w-40">
            <Icon name="lucide:shield-check" class="h-10 w-10 text-cyan mb-2" />
            <span class="text-sm font-bold text-cyan">SMART</span>
            <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.smartDesc')}</span>
          </div>

          <Icon name="lucide:arrow-right" class="h-6 w-6 text-cyan rotate-90 sm:rotate-0" />

          <!-- Apps -->
          <div class="flex flex-col items-center rounded-2xl border-2 border-emerald/30 bg-emerald/5 p-6 text-center w-40">
            <Icon name="lucide:layout-grid" class="h-10 w-10 text-emerald mb-2" />
            <span class="text-sm font-bold text-emerald">Apps</span>
            <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.appsDesc')}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
