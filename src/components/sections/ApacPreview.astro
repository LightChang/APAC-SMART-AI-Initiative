---
import { Icon } from 'astro-icon/components';
import Card from '@/components/ui/Card.astro';
import { t, getLocalizedPath } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const pains = [
  { key: 'pain1', icon: 'lucide:unplug', color: 'text-red-500' },
  { key: 'pain2', icon: 'lucide:users', color: 'text-amber-500' },
  { key: 'pain3', icon: 'lucide:trending-up', color: 'text-orange-500' },
];
---

<section class="py-16 sm:py-24 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl font-bold text-navy sm:text-4xl">
        {t(locale, 'apacPreview.title')}
      </h2>
      <p class="mx-auto mt-3 max-w-3xl text-lg text-muted leading-relaxed">
        {t(locale, 'apacPreview.subtitle')}
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      {pains.map(({ key, icon, color }) => (
        <Card>
          <Icon name={icon} class={`h-8 w-8 ${color} mb-4`} />
          <h3 class="font-heading text-lg font-bold text-navy">
            {t(locale, `apacPreview.${key}Title`)}
          </h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">
            {t(locale, `apacPreview.${key}Desc`)}
          </p>
        </Card>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href={getLocalizedPath(locale, 'apac-opportunity')}
        class="inline-flex items-center gap-1 text-cyan font-medium hover:text-cyan-dark transition-colors"
      >
        {t(locale, 'apacPreview.link')}
        <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
