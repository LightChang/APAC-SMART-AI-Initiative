---
import Button from '@/components/ui/Button.astro';
import { t, getLocalizedPath } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="bg-gradient-to-r from-navy to-navy-light py-16 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl">
      {t(locale, 'bottomCta.title')}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-white/70">
      {t(locale, 'bottomCta.subtitle')}
    </p>
    <div class="mt-8">
      <Button href={getLocalizedPath(locale, 'get-involved')} variant="primary" size="lg">
        {t(locale, 'bottomCta.button')}
      </Button>
    </div>
  </div>
</section>
