---
import { Icon } from 'astro-icon/components';
import { locales, localesByRegion, regionLabels, type Locale } from '@/i18n/config';
import { getLocalizedPath, getRawPagePath } from '@/i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const rawPagePath = getRawPagePath(currentPath);
const currentConfig = locales[locale];
---

<div
  class="relative"
  x-data="{ open: false }"
  @keydown.escape.window="open = false"
>
  <!-- Trigger Button -->
  <button
    @click="open = !open"
    class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-medium text-muted hover:bg-slate-bg hover:text-navy transition-colors"
    :aria-expanded="open"
    aria-haspopup="true"
  >
    <Icon name="lucide:globe" class="h-4 w-4" />
    <span class="hidden sm:inline">{currentConfig.label}</span>
    <span class="sm:hidden">{locale.toUpperCase().slice(0, 2)}</span>
    <Icon name="lucide:chevron-down" class="h-3 w-3 transition-transform" x-bind:class="{ 'rotate-180': open }" />
  </button>

  <!-- Dropdown Panel -->
  <div
    x-show="open"
    x-transition:enter="transition ease-out duration-100"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
    x-transition:leave="transition ease-in duration-75"
    x-transition:leave-start="opacity-100 scale-100"
    x-transition:leave-end="opacity-0 scale-95"
    @click.outside="open = false"
    x-cloak
    class="absolute right-0 top-full mt-2 w-72 max-h-[70vh] overflow-y-auto rounded-xl border border-border bg-white shadow-lg z-50"
  >
    <div class="p-2">
      {Object.entries(localesByRegion).map(([region, localeList]) => (
        <div class="mb-2 last:mb-0">
          <div class="px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-muted">
            {regionLabels[region as keyof typeof regionLabels][locale.startsWith('zh') ? 'zh' : 'en']}
          </div>
          <div class="space-y-0.5">
            {localeList.map((loc) => {
              const config = locales[loc];
              const isActive = loc === locale;
              return (
                <a
                  href={getLocalizedPath(loc, rawPagePath)}
                  class:list={[
                    'flex items-center justify-between rounded-lg px-3 py-2 text-sm transition-colors',
                    isActive
                      ? 'bg-cyan/10 text-cyan font-medium'
                      : 'text-body hover:bg-slate-bg hover:text-navy',
                  ]}
                  onclick="localStorage.setItem('apac-preferred-locale', this.dataset.locale)"
                  data-locale={loc}
                >
                  <span>{config.label}</span>
                  {isActive && <Icon name="lucide:check" class="h-4 w-4" />}
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
