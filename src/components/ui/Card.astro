---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;
---

<div class:list={[
  'rounded-2xl border border-border bg-white p-6 sm:p-8',
  hover && 'transition-all duration-200 hover:shadow-lg hover:border-cyan/20 hover:-translate-y-0.5',
  className,
]}>
  <slot />
</div>
