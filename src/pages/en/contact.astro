---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';

const locale = 'en';
const faqs = ['1', '2', '3', '4', '5'];
const roles = ['roleHealthcare', 'roleDeveloper', 'rolePolicy', 'roleResearcher', 'roleOther'];
---

<BaseLayout
  title={`${t(locale, 'contact.pageTitle')} - ${t(locale, 'site.title')}`}
  description={t(locale, 'contact.pageDescription')}
  locale={locale}
  path="contact"
>
  <section class="bg-gradient-to-br from-navy to-navy-light py-16 sm:py-24 text-center">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">{t(locale, 'contact.heroTitle')}</h1>
      <p class="mt-4 text-lg text-white/70">{t(locale, 'contact.heroSubtitle')}</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <h2 class="font-heading text-2xl font-bold text-navy mb-6">{t(locale, 'contact.form.title')}</h2>
          <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-5">
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-navy mb-1">{t(locale, 'contact.form.name')}</label>
                <input type="text" id="name" name="name" required placeholder={t(locale, 'contact.form.namePlaceholder')} class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-1">{t(locale, 'contact.form.email')}</label>
                <input type="email" id="email" name="email" required placeholder={t(locale, 'contact.form.emailPlaceholder')} class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan" />
              </div>
            </div>
            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="org" class="block text-sm font-medium text-navy mb-1">{t(locale, 'contact.form.org')}</label>
                <input type="text" id="org" name="organization" placeholder={t(locale, 'contact.form.orgPlaceholder')} class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan" />
              </div>
              <div>
                <label for="role" class="block text-sm font-medium text-navy mb-1">{t(locale, 'contact.form.role')}</label>
                <select id="role" name="role" class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan">
                  <option value="">{t(locale, 'contact.form.rolePlaceholder')}</option>
                  {roles.map((role) => (<option value={role}>{t(locale, `contact.form.${role}`)}</option>))}
                </select>
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-1">{t(locale, 'contact.form.message')}</label>
              <textarea id="message" name="message" rows="5" required placeholder={t(locale, 'contact.form.messagePlaceholder')} class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan resize-none"></textarea>
            </div>
            <button type="submit" class="rounded-xl bg-cyan px-8 py-3 font-medium text-white hover:bg-cyan-dark transition-colors">{t(locale, 'contact.form.submit')}</button>
          </form>
        </div>

        <div>
          <h2 class="font-heading text-2xl font-bold text-navy mb-6">{t(locale, 'contact.social.title')}</h2>
          <p class="text-muted mb-6">{t(locale, 'contact.social.subtitle')}</p>
          <div class="space-y-4">
            <a href="#" class="flex items-center gap-3 rounded-xl border border-border bg-white p-4 transition-all hover:shadow-md hover:border-cyan/20">
              <Icon name="lucide:linkedin" class="h-6 w-6 text-[#0077B5]" /><span class="text-sm font-medium text-navy">LinkedIn</span>
            </a>
            <a href="#" class="flex items-center gap-3 rounded-xl border border-border bg-white p-4 transition-all hover:shadow-md hover:border-cyan/20">
              <Icon name="lucide:twitter" class="h-6 w-6 text-navy" /><span class="text-sm font-medium text-navy">X / Twitter</span>
            </a>
            <a href="https://github.com/smart-on-fhir" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-xl border border-border bg-white p-4 transition-all hover:shadow-md hover:border-cyan/20">
              <Icon name="lucide:github" class="h-6 w-6 text-navy" /><span class="text-sm font-medium text-navy">GitHub</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-slate-bg">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title={t(locale, 'contact.faq.title')} />
      <div class="mt-8 space-y-4" x-data="{ openFaq: null }">
        {faqs.map((num) => (
          <div class="rounded-xl border border-border bg-white overflow-hidden">
            <button @click={`openFaq = openFaq === ${num} ? null : ${num}`} class="flex w-full items-center justify-between px-6 py-4 text-left">
              <span class="font-medium text-navy">{t(locale, `contact.faq.q${num}`)}</span>
              <Icon name="lucide:chevron-down" class="h-5 w-5 text-muted transition-transform" x-bind:class={`{ 'rotate-180': openFaq === ${num} }`} />
            </button>
            <div x-show={`openFaq === ${num}`} x-collapse x-cloak class="px-6 pb-4 text-sm text-muted leading-relaxed">
              {t(locale, `contact.faq.a${num}`)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
