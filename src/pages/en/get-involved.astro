---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';

const locale = 'en';

const paths = [
  { key: 'healthcare', icon: 'lucide:hospital', color: 'text-cyan bg-cyan/10', items: ['item1', 'item2', 'item3', 'item4'] },
  { key: 'developer', icon: 'lucide:code-2', color: 'text-emerald bg-emerald/10', items: ['item1', 'item2', 'item3', 'item4'] },
  { key: 'policy', icon: 'lucide:landmark', color: 'text-violet-600 bg-violet-50', items: ['item1', 'item2', 'item3', 'item4'] },
];
---

<BaseLayout
  title={`${t(locale, 'involve.pageTitle')} - ${t(locale, 'site.title')}`}
  description={t(locale, 'involve.pageDescription')}
  locale={locale}
  path="get-involved"
>
  <section class="bg-gradient-to-br from-navy to-navy-light py-16 sm:py-24 text-center">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">{t(locale, 'involve.heroTitle')}</h1>
      <p class="mt-4 text-lg text-white/70">{t(locale, 'involve.heroSubtitle')}</p>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title={t(locale, 'involve.paths.title')} subtitle={t(locale, 'involve.paths.subtitle')} />
      <div class="grid gap-8 lg:grid-cols-3 mt-8">
        {paths.map(({ key, icon, color, items }) => (
          <Card class="flex flex-col">
            <div class={`inline-flex rounded-xl p-3 ${color} mb-4 self-start`}><Icon name={icon} class="h-7 w-7" /></div>
            <h3 class="font-heading text-xl font-bold text-navy">{t(locale, `involve.${key}.title`)}</h3>
            <p class="mt-1 text-sm text-muted">{t(locale, `involve.${key}.subtitle`)}</p>
            <ul class="mt-4 space-y-2 flex-1">
              {items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <Icon name="lucide:check" class="h-4 w-4 text-emerald mt-0.5 shrink-0" />
                  {t(locale, `involve.${key}.${item}`)}
                </li>
              ))}
            </ul>
            <div class="mt-6"><Button href="#" variant="outline" size="sm">{t(locale, `involve.${key}.cta`)}</Button></div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-gradient-to-r from-navy to-navy-light">
    <div class="mx-auto max-w-2xl px-4 text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl">{t(locale, 'involve.newsletter.title')}</h2>
      <p class="mt-3 text-lg text-white/70">{t(locale, 'involve.newsletter.subtitle')}</p>
      <form class="mt-8 flex flex-col gap-3 sm:flex-row sm:gap-2" action="https://formspree.io/f/placeholder" method="POST">
        <input type="email" name="email" required placeholder={t(locale, 'involve.newsletter.placeholder')} class="flex-1 rounded-xl border border-white/20 bg-white/10 px-4 py-3 text-white placeholder:text-white/40 focus:border-cyan focus:outline-none focus:ring-1 focus:ring-cyan" />
        <button type="submit" class="rounded-xl bg-cyan px-6 py-3 font-medium text-white hover:bg-cyan-dark transition-colors">{t(locale, 'involve.newsletter.button')}</button>
      </form>
      <p class="mt-3 text-sm text-white/50">{t(locale, 'involve.newsletter.privacy')}</p>
    </div>
  </section>
</BaseLayout>
