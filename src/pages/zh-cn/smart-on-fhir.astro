---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Card from '@/components/ui/Card.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';
import timeline from '@/assets/data/timeline.json';
import partners from '@/assets/data/partners.json';

const locale = 'zh-cn';
const categories = {
  standards: t(locale, 'smart.ecosystem.standards'),
  government: t(locale, 'smart.ecosystem.government'),
  vendor: t(locale, 'smart.ecosystem.vendors'),
  cloud: t(locale, 'smart.ecosystem.cloud'),
};
---

<BaseLayout
  title={`${t(locale, 'smart.pageTitle')} - ${t(locale, 'site.title')}`}
  description={t(locale, 'smart.pageDescription')}
  locale={locale}
  path="smart-on-fhir"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy to-navy-light py-16 sm:py-24 text-center">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">
        {t(locale, 'smart.heroTitle')}
      </h1>
      <p class="mt-4 text-lg text-white/70">{t(locale, 'smart.heroSubtitle')}</p>
    </div>
  </section>

  <!-- Three-part explanation -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-3">
        {[
          { key: 'whatIsFhir', icon: 'lucide:file-json', color: 'bg-blue-50 text-blue-600' },
          { key: 'whatIsSmart', icon: 'lucide:shield-check', color: 'bg-cyan/10 text-cyan' },
          { key: 'whyMatters', icon: 'lucide:heart-handshake', color: 'bg-emerald/10 text-emerald' },
        ].map(({ key, icon, color }) => (
          <Card>
            <div class={`inline-flex rounded-xl p-3 ${color} mb-4`}>
              <Icon name={icon} class="h-6 w-6" />
            </div>
            <h3 class="font-heading text-xl font-bold text-navy">
              {t(locale, `smart.${key}.title`)}
            </h3>
            <p class="mt-3 text-muted leading-relaxed">
              {t(locale, `smart.${key}.description`)}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Concept Diagram -->
  <section class="py-16 bg-slate-bg">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-center sm:gap-8">
        <div class="flex flex-col items-center rounded-2xl border-2 border-navy/20 bg-white p-8 text-center w-48">
          <Icon name="lucide:database" class="h-12 w-12 text-navy mb-3" />
          <span class="font-bold text-navy">{t(locale, 'smart.conceptDiagram.ehr')}</span>
          <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.ehrDesc')}</span>
        </div>
        <Icon name="lucide:arrow-right" class="h-8 w-8 text-cyan rotate-90 sm:rotate-0" />
        <div class="flex flex-col items-center rounded-2xl border-2 border-cyan bg-cyan/5 p-8 text-center w-48">
          <Icon name="lucide:shield-check" class="h-12 w-12 text-cyan mb-3" />
          <span class="font-bold text-cyan">{t(locale, 'smart.conceptDiagram.smartLayer')}</span>
          <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.smartDesc')}</span>
        </div>
        <Icon name="lucide:arrow-right" class="h-8 w-8 text-cyan rotate-90 sm:rotate-0" />
        <div class="flex flex-col items-center rounded-2xl border-2 border-emerald/30 bg-emerald/5 p-8 text-center w-48">
          <Icon name="lucide:layout-grid" class="h-12 w-12 text-emerald mb-3" />
          <span class="font-bold text-emerald">{t(locale, 'smart.conceptDiagram.apps')}</span>
          <span class="text-xs text-muted mt-1">{t(locale, 'smart.conceptDiagram.appsDesc')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'smart.timeline.title')}
        subtitle={t(locale, 'smart.timeline.subtitle')}
      />
      <div class="relative mt-8">
        <!-- Vertical line -->
        <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-border sm:left-1/2 sm:-translate-x-0.5"></div>

        {timeline.map((item, i) => (
          <div class:list={[
            'relative mb-8 flex items-start gap-6',
            i % 2 === 0 ? 'sm:flex-row-reverse' : '',
          ]}>
            <!-- Dot -->
            <div class="absolute left-4 sm:left-1/2 -translate-x-1/2 h-3 w-3 rounded-full bg-cyan border-2 border-white ring-2 ring-cyan/30 z-10"></div>

            <!-- Content -->
            <div class:list={[
              'ml-12 sm:ml-0 sm:w-5/12',
              i % 2 === 0 ? 'sm:text-right sm:mr-auto' : 'sm:ml-auto',
            ]}>
              <span class="inline-block rounded-full bg-cyan/10 px-3 py-1 text-sm font-bold text-cyan">
                {item.year}
              </span>
              <p class="mt-2 text-sm text-muted leading-relaxed">
                {item[locale]}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ecosystem -->
  <section class="py-16 sm:py-24 bg-slate-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'smart.ecosystem.title')}
        subtitle={t(locale, 'smart.ecosystem.subtitle')}
      />

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mt-8">
        {Object.entries(categories).map(([cat, label]) => (
          <Card hover={false}>
            <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-cyan mb-4">{label}</h3>
            <ul class="space-y-2">
              {partners.filter(p => p.category === cat).map(p => (
                <li class="text-sm text-muted">{p.name}</li>
              ))}
            </ul>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'smart.resources.title')}
        subtitle={t(locale, 'smart.resources.subtitle')}
      />

      <div class="grid gap-6 sm:grid-cols-3 mt-8">
        {[
          { key: 'officialDocs', icon: 'lucide:book-open', href: 'https://smarthealthit.org' },
          { key: 'fhirSpec', icon: 'lucide:file-text', href: 'https://hl7.org/fhir/' },
          { key: 'sandbox', icon: 'lucide:play-circle', href: 'https://launch.smarthealthit.org' },
        ].map(({ key, icon, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" class="group">
            <Card>
              <Icon name={icon} class="h-8 w-8 text-cyan mb-3" />
              <h3 class="font-heading text-lg font-bold text-navy group-hover:text-cyan transition-colors">
                {t(locale, `smart.resources.${key}`)}
              </h3>
              <p class="mt-2 text-sm text-muted">
                {t(locale, `smart.resources.${key}Desc`)}
              </p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm text-cyan font-medium">
                {t(locale, 'cta.learnMore')}
                <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
              </span>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
