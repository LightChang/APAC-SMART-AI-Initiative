---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Card from '@/components/ui/Card.astro';
import MetricCard from '@/components/ui/MetricCard.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';
import countries from '@/assets/data/countries.json';

const locale = 'zh-cn';

const statusColors = {
  advanced: { bg: 'bg-emerald/10', text: 'text-emerald', border: 'border-emerald/30', dot: 'bg-emerald' },
  growing: { bg: 'bg-cyan/10', text: 'text-cyan', border: 'border-cyan/30', dot: 'bg-cyan' },
  emerging: { bg: 'bg-amber-50', text: 'text-amber-600', border: 'border-amber-200', dot: 'bg-amber-400' },
};
---

<BaseLayout
  title={`${t(locale, 'apac.pageTitle')} - ${t(locale, 'site.title')}`}
  description={t(locale, 'apac.pageDescription')}
  locale={locale}
  path="apac-opportunity"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy to-navy-light py-16 sm:py-24 text-center">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">
        {t(locale, 'apac.heroTitle')}
      </h1>
      <p class="mt-4 text-lg text-white/70">{t(locale, 'apac.heroSubtitle')}</p>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'apac.painPoints.title')}
        subtitle={t(locale, 'apac.painPoints.subtitle')}
      />
      <div class="grid gap-6 sm:grid-cols-3 mt-8">
        {[
          { key: 'pain1', icon: 'lucide:unplug', color: 'text-red-500 bg-red-50' },
          { key: 'pain2', icon: 'lucide:users', color: 'text-amber-500 bg-amber-50' },
          { key: 'pain3', icon: 'lucide:trending-up', color: 'text-orange-500 bg-orange-50' },
        ].map(({ key, icon, color }) => (
          <Card>
            <div class={`inline-flex rounded-xl p-3 ${color} mb-4`}>
              <Icon name={icon} class="h-6 w-6" />
            </div>
            <h3 class="font-heading text-xl font-bold text-navy">
              {t(locale, `apac.${key}.title`)}
            </h3>
            <p class="mt-3 text-sm text-muted leading-relaxed">
              {t(locale, `apac.${key}.description`)}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Market Data -->
  <section class="py-16 sm:py-24 bg-slate-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'apac.market.title')}
        subtitle={t(locale, 'apac.market.subtitle')}
      />
      <div class="grid gap-8 sm:grid-cols-3 mt-8">
        <MetricCard value={t(locale, 'apac.market.sizeValue')} label={`${t(locale, 'apac.market.size')} (${t(locale, 'apac.market.sizeYear')})`} icon="💰" />
        <MetricCard value={t(locale, 'apac.market.cagrValue')} label={`${t(locale, 'apac.market.cagr')} (${t(locale, 'apac.market.cagrPeriod')})`} icon="📈" />
        <MetricCard value={t(locale, 'apac.market.adoptionValue')} label={t(locale, 'apac.market.adoptionDesc')} icon="🏥" />
      </div>
    </div>
  </section>

  <!-- Map Legend -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'apac.map.title')}
        subtitle={t(locale, 'apac.map.subtitle')}
      />

      <!-- Legend -->
      <div class="flex flex-wrap justify-center gap-6 mb-10">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-emerald"></span>
          <span class="text-sm text-muted">{t(locale, 'apac.map.statusAdvanced')}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-cyan"></span>
          <span class="text-sm text-muted">{t(locale, 'apac.map.statusGrowing')}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-amber-400"></span>
          <span class="text-sm text-muted">{t(locale, 'apac.map.statusEmerging')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study: Timor-Leste -->
  <section class="py-16 sm:py-24 bg-slate-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'apac.caseStudy.title')}
        subtitle={t(locale, 'apac.caseStudy.subtitle')}
      />
      <div class="mt-8 rounded-2xl border border-cyan/20 bg-white p-8 sm:p-10">
        <div class="grid gap-8 lg:grid-cols-3">
          <div class="lg:col-span-2">
            <p class="text-muted leading-relaxed">{t(locale, 'apac.caseStudy.description')}</p>
          </div>
          <div class="grid grid-cols-3 lg:grid-cols-1 gap-4">
            {['stat1', 'stat2', 'stat3'].map((key) => (
              <div class="text-center lg:text-left">
                <p class="font-heading text-lg font-bold text-cyan">{t(locale, `apac.caseStudy.${key}Value`)}</p>
                <p class="text-xs text-muted">{t(locale, `apac.caseStudy.${key}Label`)}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Country Cards -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title={t(locale, 'apac.countries.title')}
        subtitle={t(locale, 'apac.countries.subtitle')}
      />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-8">
        {countries.map((country) => {
          const colors = statusColors[country.status as keyof typeof statusColors];
          return (
            <Card>
              <div class="flex items-center gap-3 mb-3">
                <span class={`h-2.5 w-2.5 rounded-full ${colors.dot}`}></span>
                <h3 class="font-heading text-lg font-bold text-navy">
                  {country[locale].name}
                </h3>
              </div>
              <p class="text-sm text-muted leading-relaxed">
                {country[locale].highlights}
              </p>
            </Card>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
