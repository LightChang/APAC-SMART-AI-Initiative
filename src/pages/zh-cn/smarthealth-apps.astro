---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Card from '@/components/ui/Card.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n/utils';
import appsData from '@/assets/data/smarthealth-apps.json';

const locale = 'zh-cn';
---

<BaseLayout
  title={`${t(locale, 'apps.pageTitle')} - ${t(locale, 'site.title')}`}
  description={t(locale, 'apps.pageDescription')}
  locale={locale}
  path="smarthealth-apps"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy to-navy-light py-16 sm:py-24 text-center">
    <div class="mx-auto max-w-4xl px-4">
      <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm text-white/80 mb-6">
        <Icon name="lucide:layout-grid" class="h-4 w-4" />
        <span>SMART on FHIR</span>
      </div>
      <h1 class="font-heading text-4xl font-bold text-white sm:text-5xl">
        {t(locale, 'apps.heroTitle')}
      </h1>
      <p class="mt-4 text-lg text-white/70">{t(locale, 'apps.heroSubtitle')}</p>
    </div>
  </section>

  <!-- Intro & Metrics -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <h2 class="font-heading text-2xl font-bold text-navy sm:text-3xl">
            {t(locale, 'apps.intro.title')}
          </h2>
          <p class="mt-4 text-muted leading-relaxed">
            {t(locale, 'apps.intro.description')}
          </p>
        </div>
        <div class="lg:col-span-2 grid grid-cols-3 gap-4">
          {[
            { value: t(locale, 'apps.intro.totalApps'), label: t(locale, 'apps.intro.totalAppsLabel'), color: 'text-cyan' },
            { value: t(locale, 'apps.intro.categories'), label: t(locale, 'apps.intro.categoriesLabel'), color: 'text-emerald' },
            { value: t(locale, 'apps.intro.ehrSupport'), label: t(locale, 'apps.intro.ehrSupportLabel'), color: 'text-blue-600' },
          ].map(({ value, label, color }) => (
            <div class="rounded-2xl border border-border bg-white p-4 text-center">
              <div class={`text-3xl font-bold ${color}`}>{value}</div>
              <div class="mt-1 text-xs text-muted">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- App Categories -->
  {appsData.map((category, catIndex) => (
    <section class:list={['py-16 sm:py-20', catIndex % 2 === 0 ? 'bg-slate-bg' : '']}>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-3">
          <div class="inline-flex rounded-xl bg-cyan/10 p-2.5">
            <Icon name={category.icon} class="h-6 w-6 text-cyan" />
          </div>
          <h2 class="font-heading text-2xl font-bold text-navy">
            {t(locale, `apps.categories.${category.category}.title`)}
          </h2>
          <span class="rounded-full bg-navy/10 px-2.5 py-0.5 text-xs font-medium text-navy">
            {category.apps.length}
          </span>
        </div>
        <p class="text-muted mb-8 max-w-3xl">
          {t(locale, `apps.categories.${category.category}.description`)}
        </p>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {category.apps.map((app) => (
            <a href={app.url} target="_blank" rel="noopener noreferrer" class="group">
              <Card>
                <div class="flex items-start justify-between gap-2 mb-3">
                  <h3 class="font-heading text-base font-bold text-navy group-hover:text-cyan transition-colors leading-tight">
                    {app.name}
                  </h3>
                  <Icon name="lucide:external-link" class="h-4 w-4 text-muted shrink-0 group-hover:text-cyan transition-colors mt-0.5" />
                </div>
                <p class="text-xs text-cyan font-medium mb-2">{app.developer}</p>
                <p class="text-sm text-muted leading-relaxed line-clamp-3">
                  {t(locale, `apps.appDescriptions.${app.name}`)}
                </p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {app.fhir.map((v: string) => (
                    <span class="rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-medium text-blue-600">
                      {v}
                    </span>
                  ))}
                  {app.ehr.map((e: string) => (
                    <span class="rounded-full bg-emerald/10 px-2 py-0.5 text-[10px] font-medium text-emerald">
                      {e}
                    </span>
                  ))}
                  {app.os.map((o: string) => (
                    <span class="rounded-full bg-navy/5 px-2 py-0.5 text-[10px] font-medium text-navy/70">
                      {o}
                    </span>
                  ))}
                </div>
              </Card>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA: Visit Gallery -->
  <section class="py-16 sm:py-24 bg-gradient-to-br from-navy to-navy-light">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <Icon name="lucide:globe" class="h-12 w-12 text-cyan mx-auto mb-4" />
      <h2 class="font-heading text-2xl font-bold text-white sm:text-3xl">
        {t(locale, 'apps.galleryLink.title')}
      </h2>
      <p class="mt-4 text-white/70">
        {t(locale, 'apps.galleryLink.description')}
      </p>
      <a
        href="https://apps.smarthealthit.org/apps?sort=name-asc"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-xl bg-cyan px-6 py-3 font-medium text-white hover:bg-cyan/90 transition-colors"
      >
        {t(locale, 'apps.galleryLink.button')}
        <Icon name="lucide:external-link" class="h-4 w-4" />
      </a>
    </div>
  </section>
</BaseLayout>
