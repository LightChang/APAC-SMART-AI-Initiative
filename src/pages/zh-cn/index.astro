---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import KeyMetrics from '@/components/sections/KeyMetrics.astro';
import SmartIntro from '@/components/sections/SmartIntro.astro';
import ApacPreview from '@/components/sections/ApacPreview.astro';
import PartnerGrid from '@/components/sections/PartnerGrid.astro';
import BottomCta from '@/components/sections/BottomCta.astro';
import { t } from '@/i18n/utils';

const locale = 'zh-cn';
---

<BaseLayout
  title={t(locale, 'site.title')}
  description={t(locale, 'site.description')}
  locale={locale}
  path=""
>
  <Hero locale={locale} />
  <KeyMetrics locale={locale} />
  <SmartIntro locale={locale} />
  <ApacPreview locale={locale} />
  <PartnerGrid locale={locale} />
  <BottomCta locale={locale} />
</BaseLayout>
