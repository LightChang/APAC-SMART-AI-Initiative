---
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-sc';
import '@/styles/global.css';
import BaseHead from '@/components/seo/BaseHead.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import type { Locale } from '@/i18n/config';
import { getLocaleConfig } from '@/i18n/utils';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path?: string;
}

const { title, description, locale, path } = Astro.props;
const config = getLocaleConfig(locale);
---

<!doctype html>
<html lang={config.lang} dir={config.dir}>
  <head>
    <BaseHead {title} {description} {locale} {path} />
  </head>
  <body class="min-h-screen flex flex-col bg-warm-white text-body">
    <Header locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
